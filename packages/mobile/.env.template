# Mobile env vars live in the monorepo root — single source of truth:
#
#   contentbrain/.env
#
# Copy from root:
#   cp ../../.env.template ../../.env
#
# Relevant keys for Expo:
#   EXPO_PUBLIC_API_URL   — API base URL (use LAN IP on a physical device)
#   EXPO_PACKAGER_PROXY_URL
#
# Expo loads ../../.env via app.config.ts — you do not need a separate .env here.
