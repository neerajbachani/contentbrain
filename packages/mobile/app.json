{
  "expo": {
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.contentbrain_x9k2.runable",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#061B09"
      },
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "apiUrl": "https://trasoa6aieps6dmh515b6-preview-4200.runable.site/"
    },
    "ios": {
      "bundleIdentifier": "com.contentbrain_x9k2.runable",
      "supportsTablet": true
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#061B09"
    },
    "name": "ContentBrain",
    "slug": "contentbrain",
    "version": "1.0.0",
    "scheme": "contentbrain",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow ContentBrain to save meme images to your photo library.",
          "savePhotosPermission": "Allow ContentBrain to save meme images to your photo library."
        }
      ]
    ]
  }
}
