# =============================================================================
# ContentBrain — environment variables (monorepo root)
# =============================================================================
# Copy this file to `.env` and fill in values:
#   cp .env.template .env
#
# Used by:
#   - packages/web  (Vite + Hono API) — loadEnv from this directory
#   - packages/web  (Drizzle)         — bun --env-file=../../.env
#   - packages/mobile (Expo)          — app.config.ts loads ../../.env
#
# Never commit `.env` (gitignored).
# =============================================================================

# --- App ---------------------------------------------------------------------
NODE_ENV=development

# Dev only — treat free users as premium (live X context, trend refresh). Never true in prod.
DEV_GRANT_PREMIUM=false

# Free-tier caps (optional overrides; defaults: 30 inspirations, 20 remixes, 10 merges, 20 trends/day)
# FREE_MAX_INSPIRATIONS=30
# FREE_DAILY_REMIXES=20
# FREE_DAILY_MERGES=10
# FREE_DAILY_TRENDS=20

# Public URL of the web/API server (Better Auth base URL). Must match the URL
# you open in the browser during local dev (check the port Vite prints).
WEBSITE_URL=http://localhost:5173

# --- Auth (required) ---------------------------------------------------------
# Generate: openssl rand -hex 32  (or any long random string)
BETTER_AUTH_SECRET=your-better-auth-secret-here

# --- Database — Turso / LibSQL (required) ------------------------------------
# https://turso.tech → create database → connect
DATABASE_URL=libsql://your-database-name-your-org.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token-here

# --- AI — Remix, merge, inspiration analysis (optional) ----------------------
# Use either AI gateway vars OR OpenAI directly.
# OpenRouter (replaces AI gateway — get key at openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Merge cover image generation (OpenRouter image-capable models)
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
OPENROUTER_IMAGE_MODEL_WITH_REFS=google/gemini-2.5-flash-image
MERGE_IMAGE_MAX_REFS=5
MERGE_IMAGE_ASPECT_RATIO=16:9
MERGE_IMAGE_SIZE=1K

# --- Trends pipeline — Reddit (optional, OAuth recommended) ------------------
# https://www.reddit.com/prefs/apps → create "script" or "web app" app
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=ContentBrain/1.0 by YourRedditUsername

# --- Trends pipeline — NewsData.io (optional) --------------------------------
# https://newsdata.io — free tier ~200 requests/day
NEWSDATA_API_KEY=your-newsdata-api-key

# --- Trends pipeline — Apify / X Twitter (optional) --------------------------
# https://apify.com — actor hardcoded as quacker~twitter-scraper
# Note: Apify is disabled in the 6h cron by default (cost control).
APIFY_API_TOKEN=your-apify-api-token
# Set to false to skip X on premium manual trend refresh
APIFY_X_TRENDS_ENABLED=true
# Trends feed: X posts prefer user Grok OAuth (Settings). Apify is optional fallback.

# --- Live X context (Grok x_search + Apify) ----------------------------------
# Encrypts pasted Grok OAuth tokens (falls back to BETTER_AUTH_SECRET)
CREDENTIALS_ENCRYPTION_KEY=
# Max live X context/research calls per premium user per day (Apify path)
X_CONTEXT_DAILY_LIMIT=20
# xAI Responses API when user connects Grok (optional overrides)
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.1-fast

# --- Mobile — Expo (optional for local dev) ----------------------------------
# API base URL for the React Native app. Use your PC LAN IP when testing on a
# physical phone (not localhost). Overrides app.json extra.apiUrl when set.
# Example: http://192.168.1.42:5173
EXPO_PUBLIC_API_URL=http://localhost:5173

# Expo packager proxy (optional; tunnel / corporate network)
EXPO_PACKAGER_PROXY_URL=

# --- Payments (optional — not wired in app yet) ------------------------------
AUTUMN_SECRET_KEY=
